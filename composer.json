{
    "name": "shanginn/wtf_happend_bot",
    "description": "Bot that will summarize the chat messages for you using Temporal Agentic Loop",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Bot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "authors": [
        {
            "name": "Nikolai Shangin",
            "email": "shanginn@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-pcntl": "*",
        "shanginn/openai-sdk": "^2.0.0-beta",
        "phenogram/framework": "^5.4",
        "vlucas/phpdotenv": "^5.6",
        "cycle/orm": "^2.10",
        "cycle/migrations": "^4.2",
        "cycle/schema-migrations-generator": "^2.3",
        "cycle/annotated": "^4.2",
        "symfony/var-dumper": "^8.0",
        "symfony/serializer": "^7.4",
        "temporal/sdk": "^2.16",
        "spiral/roadrunner-cli": "^2.7"
    },
    "minimum-stability": "stable",
    "scripts": {
        "fix": "PHP_CS_FIXER_IGNORE_ENV=1 ./tools/vendor/bin/php-cs-fixer fix src --diff -vvv --config=.php-cs-fixer.php"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "fakerphp/faker": "^1.24",
        "mockery/mockery": "^1.6",
        "buggregator/trap": "^1.15"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
